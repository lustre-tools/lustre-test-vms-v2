#!/bin/sh
# Post-commit hook: bake the new HEAD short hash into ltvm_pkg/_build_info.py
# so `ltvm --version` reports e.g. "0.10.abc1234" without shelling out
# to git on every import.
#
# The generated file is gitignored; the hook overwrites it on every commit.
# Install: git config core.hooksPath .githooks

set -e

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
hash=$(git rev-parse --short HEAD 2>/dev/null) || exit 0

out="$repo_root/ltvm_pkg/_build_info.py"
cat > "$out" <<EOF
"""Auto-generated by .githooks/post-commit. Do not edit or commit."""

BUILD_HASH = "$hash"
EOF
