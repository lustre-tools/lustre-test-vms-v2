        "an identical release anyway.",
    )
    tfp.add_argument(
        "--force",
        action="store_true",
        help="With --replace, re-fetch even when the local tag "
        "already matches the remote release.",
    )
    tfp.add_argument(
        "--variant",
        default="base",
        help="Target variant to fetch (default: base). E.g. 'mofed'.",
    )
    tfp.add_argument(
        "--image",
        action="store_true",
        help="Fetch only a standalone bootable qcow2 (ignores the "
        "ecosystem assets).  Lands under output/<target>/<arch>/bootable/.",
    )
    tfp.set_defaults(func=cmd_fetch)

    # export (bootable-disk packaging for non-ltvm users)
