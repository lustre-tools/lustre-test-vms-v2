#!/usr/bin/env python3
"""ltvm -- CLI orchestrator for Lustre test VM infrastructure.

Single entry point for building containers, kernels, and VM images,
plus runtime VM management.

Command implementations live in lib/commands.py; this file owns
argparse setup and dispatch only.
"""

from __future__ import annotations

import argparse
import logging
import sys
from pathlib import Path

# Ensure lib/ is importable
sys.path.insert(0, str(Path(__file__).parent))

from lib.commands import (
    EXIT_ERROR,
    _error,
    cmd_add_target,  # noqa: F401 (used via set_defaults)
    cmd_build_all,
    cmd_build_container,
    cmd_build_image,
    cmd_build_kernel,
    cmd_build_lustre,
    cmd_cluster,
    cmd_deploy,
    cmd_exec,
    cmd_fetch,
    cmd_install,
    cmd_package,
    cmd_publish,
    cmd_setup,
    cmd_shell,
    cmd_status,
    cmd_update,
    cmd_validate,
    cmd_vm,
)

log = logging.getLogger("ltvm")


# ------------------------------------------------------------------
# Argument parsing
# ------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    # Common flags accepted by all subcommands
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument(
        "--json",
        action="store_true",
        default=False,
        help="Machine-readable JSON output",
    )
    common.add_argument(
        "-v", "--verbose", action="store_true", help="Enable verbose logging"
    )
    common.add_argument(
        "--arch",
        default=None,
        help="Target CPU architecture override (e.g. aarch64). "
        "Defaults to the target's configured arch (usually x86_64).",
    )

    # Shared --kernel flag for subcommands that operate on
    # a specific kernel version within a target
    kernel_arg = argparse.ArgumentParser(add_help=False)
    kernel_arg.add_argument(
        "--kernel",
        default=None,
        help="Kernel version (default: from kernel.conf)",
    )

    p = argparse.ArgumentParser(
        prog="ltvm",
        description="Lustre test VM infrastructure CLI",
        parents=[common],
    )

    sub = p.add_subparsers(dest="command")

    # -- install (host setup) --
    sp = sub.add_parser(
        "install",
        parents=[common],
        aliases=["setup"],
        help="Install ltvm: QEMU, network, scripts, SSH, ltvm to PATH",
    )
    sp.add_argument(
        "--qemu", action="store_true", help="Build and install QEMU only"
    )
    sp.add_argument(
        "--network", action="store_true", help="Configure bridge + dnsmasq only"
    )
    sp.add_argument(
        "--install",
        action="store_true",
        help="Install vm.sh + deploy-lustre.sh only",
    )
    sp.add_argument(
        "--ssh", action="store_true", help="Configure host SSH only"
    )
    sp.add_argument(
        "--verify",
        action="store_true",
        help="Check existing setup (no changes)",
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Force rebuild of installed components",
    )
    sp.add_argument(
        "--subnet",
        default="192.168.100",
        help="Bridge subnet (default: 192.168.100)",
    )
    sp.set_defaults(func=cmd_setup)

    # -- add-target --
    sp = sub.add_parser(
        "add-target",
        parents=[common],
        help="Scaffold a new target (directory, Dockerfiles, YAML entry)",
    )
    sp.add_argument("name", help="Target name (e.g. rocky8, ubuntu2404)")
    sp.add_argument(
        "--image",
        required=True,
        help="Container base image (e.g. rockylinux:8.10, ubuntu:24.04)",
    )
    sp.add_argument(
        "--kernel",
        default=None,
        help="Default Lustre kernel target name (e.g. 4.18-rhel8.10)",
    )
    sp.add_argument(
        "--srpm-url",
        default=None,
        help="Base URL for kernel SRPM downloads",
    )
    sp.add_argument(
        "--no-server",
        action="store_true",
        help="Mark target as client-only (no server builds)",
    )
    sp.set_defaults(func=cmd_add_target)

    # -- build-all --
    sp = sub.add_parser(
        "build-all",
        parents=[common, kernel_arg],
        help="Build container + kernel + image from scratch",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree", help="Path to Lustre source tree (default: cwd)"
    )
    sp.add_argument(
        "--lustre-build",
        action="store_true",
        help="Also build Lustre against the target kernel",
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Rebuild even if artifacts are current",
    )
    sp.set_defaults(func=cmd_build_all)

    # -- build-container --
    sp = sub.add_parser(
        "build-container",
        parents=[common],
        help="Build the build container for a target",
    )
    sp.add_argument("target")
    sp.set_defaults(func=cmd_build_container)

    # -- build-kernel --
    sp = sub.add_parser(
        "build-kernel",
        parents=[common, kernel_arg],
        help="Build the kernel for a target",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree", help="Path to Lustre source tree (default: cwd)"
    )
    sp.add_argument(
        "--force", action="store_true", help="Rebuild even if inputs unchanged"
    )
    sp.set_defaults(func=cmd_build_kernel)

    # -- build-image --
    sp = sub.add_parser(
        "build-image",
        parents=[common],
        help="Build the VM base image for a target",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--force", action="store_true", help="Rebuild even if inputs unchanged"
    )
    sp.set_defaults(func=cmd_build_image)

    # -- build-lustre --
    sp = sub.add_parser(
        "build-lustre",
        parents=[common, kernel_arg],
        help="Build a Lustre source tree against the target kernel build-tree",
    )
    sp.add_argument(
        "target", nargs="?", default="rocky9", help="Target (default: rocky9)"
    )
    sp.add_argument(
        "--lustre-tree", help="Path to Lustre source tree (default: cwd)"
    )
    sp.add_argument(
        "--enable-server",
        action="store_true",
        default=False,
        help="Force --enable-server (default: per target.conf)",
    )
    sp.add_argument(
        "--disable-server",
        action="store_true",
        default=False,
        help="Force --disable-server",
    )
    sp.add_argument(
        "--configure", help="Extra configure arguments (quoted string)"
    )
    sp.add_argument(
        "--jobs", type=int, default=None, help="Parallel jobs (default: nproc)"
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Clean and reconfigure before building",
    )
    sp.set_defaults(func=cmd_build_lustre)

    # -- package --
    sp = sub.add_parser(
        "package",
        parents=[common, kernel_arg],
        help="Create a distributable tarball of target "
        "artifacts (kernel + image + optional Lustre)",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree",
        help="Include a built Lustre tree in the package",
    )
    sp.add_argument(
        "--output",
        default=None,
        help="Output directory for tarball (default: output/)",
    )
    sp.set_defaults(func=cmd_package)

    # -- fetch --
    sp = sub.add_parser(
        "fetch",
        parents=[common],
        help="Download pre-built target artifacts from GitHub",
    )
    sp.add_argument("target", nargs="?", default=None,
                    help="Target name (e.g. rocky9)")
    sp.add_argument("filter", nargs="?", default=None,
                    help="Optional filter (e.g. '5.14', '611')")
    sp.add_argument("--list", action="store_true",
                    help="List available releases")
    sp.add_argument("--url", default=None,
                    help="Direct URL (skip GitHub lookup)")
    sp.set_defaults(func=cmd_fetch)

    # -- publish --
    sp = sub.add_parser(
        "publish",
        parents=[common, kernel_arg],
        help="Upload a packaged tarball to a GitHub release",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--tag",
        default=None,
        help="Release tag (default: derived from tarball name)",
    )
    sp.add_argument(
        "--tarball",
        default=None,
        help="Path to tarball (default: auto-detect from output/)",
    )
    sp.set_defaults(func=cmd_publish)

    # -- shell --
    sp = sub.add_parser(
        "shell",
        parents=[common],
        help="Enter build container with source mounted",
    )
    sp.add_argument("target")
    sp.add_argument(
        "path",
        nargs="?",
        default=".",
        help="Path to mount in container (default: cwd)",
    )
    sp.set_defaults(func=cmd_shell)

    # -- status --
    sp = sub.add_parser(
        "status", parents=[common], help="Show build status of all targets"
    )
    sp.set_defaults(func=cmd_status)

    # -- update --
    sp = sub.add_parser(
        "update", parents=[common], help="Rebuild stale artifacts for a target"
    )
    sp.add_argument(
        "target",
        nargs="?",
        default=None,
        help="Target to update (required unless --all)",
    )
    sp.add_argument("--all", action="store_true", help="Update all targets")
    sp.add_argument(
        "--lustre-tree", help="Lustre source tree (needed for kernel rebuilds)"
    )
    sp.set_defaults(func=cmd_update)

    # -- validate --
    sp = sub.add_parser(
        "validate",
        parents=[common],
        help="Validate a built target (boot, packages, optional Lustre deploy)",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree",
        help="Path to Lustre build tree (enables deploy+mount checks)",
    )
    sp.set_defaults(func=cmd_validate)

    # -- vm --
    sp = sub.add_parser(
        "vm", parents=[common], help="VM management (create/ensure/destroy/...)"
    )
    sp.add_argument(
        "action",
        choices=[
            "create",
            "ensure",
            "destroy",
            "start",
            "stop",
            "restart",
            "list",
            "status",
            "mount-lustre",
        ],
        help="VM action",
    )
    sp.add_argument("vm_args", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_vm)

    # -- deploy --
    sp = sub.add_parser(
        "deploy",
        parents=[common, kernel_arg],
        help="Deploy Lustre to a VM",
    )
    sp.add_argument("vm", help="VM name")
    sp.add_argument(
        "--build", default=".", help="Lustre build tree (default: cwd)"
    )
    sp.add_argument(
        "--mount", action="store_true", help="Mount filesystem after deploy"
    )
    sp.add_argument(
        "--target",
        default=None,
        help="Target OS for kernel modules (default: auto-detect from VM)",
    )
    sp.set_defaults(func=cmd_deploy)

    # -- exec --
    sp = sub.add_parser(
        "exec", parents=[common], help="Execute a command in a VM"
    )
    sp.add_argument("vm", help="VM name")
    sp.add_argument(
        "--timeout",
        type=int,
        default=120,
        help="Command timeout in seconds (default: 120)",
    )
    sp.add_argument("cmd", nargs=argparse.REMAINDER, help="Command to run")
    sp.set_defaults(func=cmd_exec)

    # -- cluster --
    sp = sub.add_parser(
        "cluster",
        parents=[common],
        help="Cluster management (create/destroy/...)",
    )
    sp.add_argument(
        "action",
        choices=["create", "destroy", "deploy", "status", "exec"],
        help="Cluster action",
    )
    sp.add_argument("cluster_args", nargs="*")
    sp.set_defaults(func=cmd_cluster)

    return p


# ------------------------------------------------------------------
# Main
# ------------------------------------------------------------------


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    level = logging.DEBUG if args.verbose else logging.INFO
    logging.basicConfig(level=level, format="%(name)s: %(message)s")

    if not args.command:
        parser.print_help()
        return EXIT_ERROR

    # Validate update requires target or --all
    if args.command == "update":
        if not args.target and not args.all:
            return _error(
                "update requires a target or --all",
                args.json,
                hint="ltvm update <target> or ltvm update --all",
            )

    result: int = args.func(args)
    return result


if __name__ == "__main__":
    sys.exit(main())
