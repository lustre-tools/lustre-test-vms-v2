def _reconcile_target_args(args: argparse.Namespace) -> int | None:
    """Reconcile positional `target` vs --target flag.

    Both forms are first-class.  If both are given and disagree, this
    prints a clear error and returns EXIT_ERROR so the caller can abort.
    On success (or when neither form applies), returns None and sets
    args.target to the resolved value (positional takes precedence;
    falls back to the --target flag).

    Subcommands that don't use --target at all (e.g. `list`, `destroy`)
    are left untouched.
    """
    flag = getattr(args, _TARGET_FLAG_DEST, None)
    pos = getattr(args, "target", None)
    # If neither attribute was set by argparse, the subcommand doesn't
    # take a target; nothing to do.
    has_pos_attr = hasattr(args, "target")
    has_flag_attr = hasattr(args, _TARGET_FLAG_DEST)
    if not has_pos_attr and not has_flag_attr:
        return None

    if pos is not None and flag is not None and pos != flag:
        sys.stderr.write(
            "error: --target {flag!r} conflicts with positional "
            "target {pos!r}; pass only one\n".format(flag=flag, pos=pos)
        )
        return EXIT_ERROR

    resolved = pos if pos is not None else flag
    if has_pos_attr:
        args.target = resolved
    # Drop the internal sentinel so downstream code doesn't see it.
    if has_flag_attr:
        try:
            delattr(args, _TARGET_FLAG_DEST)
        except AttributeError:
            pass
    return None


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    level = logging.DEBUG if args.verbose else logging.INFO
    logging.basicConfig(level=level, format="%(name)s: %(message)s")

    if not args.command:
        parser.print_help()
        return EXIT_ERROR

    rc = _reconcile_target_args(args)
    if rc is not None:
        return rc

    # Daily self-update nag (interactive TTYs only, skipped for
    # --json, and skipped entirely for `install` to avoid recursing
    # during the install that just wrote our baked version).  See
    # ltvm_pkg/update_check.py for the full state machine.
    if args.command != "install":
        try:
            from ltvm_pkg.update_check import maybe_check_for_updates

            maybe_check_for_updates(use_json=bool(getattr(args, "json", False)))
        except Exception as e:  # noqa: BLE001
            # Update check is cosmetic -- a failure here must never
            # block the user's actual command.
            logging.getLogger("ltvm.update_check").debug(
                "update check skipped: %s", e
            )

    result: int = args.func(args)
    return result


if __name__ == "__main__":
    sys.exit(main())
