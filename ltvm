# Dest used for the --target flag on subcommands that ALSO accept a
# positional target.  We don't write to `args.target` directly from
# --target so that both sources can be reconciled (and a conflict
# detected) after argparse completes.  See _reconcile_target_args().
_TARGET_FLAG_DEST = "_target_flag"


def _add_target_arg(
    subparser: argparse.ArgumentParser,
    *,
    required: bool = False,
    positional_name: str = "target",
) -> None:
    """Attach both a positional target and a --target flag.

    Both are optional at parse time (nargs="?" / default=None); the
    cli.py reconciler enforces presence/conflict after parsing.  The
    --target flag help text is suppressed to keep --help output clean
    --the positional form is the primary, documented spelling.
    """
    help_text = "OS target (e.g. rocky9); also accepts --target"
    if required:
        help_text += " (required)"
    subparser.add_argument(
        positional_name,
        nargs="?",
        default=None,
        help=help_text,
    )
    subparser.add_argument(
        "--target",
        dest=_TARGET_FLAG_DEST,
        default=None,
        help=argparse.SUPPRESS,
    )


class _HideSuppressedSubcommands(argparse.HelpFormatter):
    """Hide subcommands registered with help=argparse.SUPPRESS."""

    def _format_action(self, action: argparse.Action) -> str:
        if action.help == argparse.SUPPRESS:
            return ""
        return super()._format_action(action)

    def _metavar_formatter(
        self, action: argparse.Action, default_metavar: str
    ) -> Any:
        # For subparser actions, strip suppressed choices from the metavar.
        if hasattr(action, "_name_parser_map"):
            # Aliases point to the same parser instance as the canonical
            # name, so dedupe by id() to keep only the first (canonical)
            # entry per parser.
            seen: set[int] = set()
            visible: list[str] = []
            for name, sp in action._name_parser_map.items():
                if sp.description == argparse.SUPPRESS:
                    continue
                if getattr(sp, "_defaults", {}).get("func") is None:
                    continue
                if id(sp) in seen:
                    continue
                seen.add(id(sp))
                visible.append(name)

            def fmt(tuple_size: int) -> tuple[Any, ...]:
                if tuple_size != 1:
                    return (tuple(visible),)
                return ("{" + ",".join(visible) + "}",)

            return fmt
        return super()._metavar_formatter(action, default_metavar)


def build_parser() -> argparse.ArgumentParser:
    # Common flags accepted by all subcommands
    common = argparse.ArgumentParser(add_help=False)
