    )
    tpkp.add_argument(
        "--variant",
        default="base",
        help="Target variant to package (default: base). E.g. 'mofed'.",
    )
    tpkp.set_defaults(func=cmd_package)

    # publish (maintainer use)
    tpbp = target_sub.add_parser(
        "publish",
        parents=[common, kernel_arg, force_compat_arg],
        help="Upload a packaged asset set to a GitHub release (maintainer)",
