    bshp.set_defaults(func=cmd_build_shell)

    bmkp = build_sub.add_parser(
        "mofed-kmods",
        parents=[common, kernel_arg, force_arg, variant_arg],
        help="Build MOFED kernel modules against the target's Lustre-patched kernel",
