#!/usr/bin/env python3
"""ltvm -- CLI orchestrator for Lustre test VM infrastructure.

Single entry point for building containers, kernels, and VM images,
plus runtime VM management.

Command implementations live in ltvm_pkg/cli.py; this file owns
argparse setup and dispatch only.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

# Self-bootstrap into the project venv when invoked via system Python
# (e.g. `sudo ltvm`, which strips PATH and bypasses any active venv).
# We resolve symlinks on __file__ so /usr/local/bin/ltvm -> repo/ltvm works,
# but compare _VENV_PY against sys.executable as literal strings -- uv venvs
# symlink .venv/bin/python to /usr/bin/python3, so .resolve() would make
# them equal even though running via the venv symlink path causes Python
# to use the venv's site-packages.
_REPO_ROOT = Path(__file__).resolve().parent
_VENV_PY = _REPO_ROOT / ".venv" / "bin" / "python"
if _VENV_PY.exists() and str(_VENV_PY) != sys.executable:
    try:
        import yaml  # noqa: F401
    except ImportError:
        os.execv(
            str(_VENV_PY),
            [str(_VENV_PY), str(Path(__file__).resolve()), *sys.argv[1:]],
        )

# NOTE: argparse/logging/cli imports are intentionally below the venv
# bootstrap above -- the bootstrap may os.execv into the venv python, in
# which case any imports here are wasted in the doomed parent process.
# E402 (module level import not at top) is suppressed for that reason.
import argparse  # noqa: E402
import logging  # noqa: E402
from typing import Any  # noqa: E402

# Ensure repo root is importable
sys.path.insert(0, str(_REPO_ROOT))

from ltvm_pkg import __version__ as LTVM_VERSION  # noqa: E402
from ltvm_pkg.cli import (  # noqa: E402
    EXIT_ERROR,
    cmd_build_all,
    cmd_build_container,
    cmd_build_image,
    cmd_build_kernel,
    cmd_build_lustre,
    cmd_build_shell,
    cmd_cluster,
    cmd_console_log,
    cmd_crash_collect,
    cmd_create,
    cmd_deploy,
    cmd_destroy,
    cmd_dmesg,
    cmd_doctor,
    cmd_ensure,
    cmd_exec,
    cmd_fetch,
    cmd_list,
    cmd_llmount,
    cmd_nmi,
    cmd_package,
    cmd_publish,
    cmd_restore,
    cmd_setup,
    cmd_snapshot,
    cmd_status,
    cmd_update,
    cmd_validate,
    cmd_vm_ssh,
    cmd_vm_start,
    cmd_vm_stop,
)

log = logging.getLogger("ltvm")


