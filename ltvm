# ------------------------------------------------------------------
# Subcommand: shell
# ------------------------------------------------------------------

def cmd_shell(args):
    use_json = args.json
    tc, err = _load_target(args.target, use_json)
    if err is not None:
        return err

    tag = f"ltvm-build-{args.target}"
    mount_path = Path(args.path).resolve()

    if not mount_path.is_dir():
        return _error(
            f"Mount path not found: {mount_path}",
            use_json)

    # Check container image exists
    result = subprocess.run(
        ["podman", "image", "exists", tag],
        capture_output=True)
    if result.returncode != 0:
        return _error(
            f"Container image {tag} not found",
            use_json,
            hint=f"Run: ltvm build-container {args.target}")

    if not use_json:
        print(f"Entering build container for {args.target} "
              f"with {mount_path} mounted at /src...")

    rc = subprocess.run(
        ["podman", "run", "--rm", "-it",
         "-v", f"{mount_path}:/src:Z",
         "-w", "/src",
         tag, "bash"]).returncode

    return rc


# ------------------------------------------------------------------
# Subcommand: status
# ------------------------------------------------------------------

def cmd_status(args):
    use_json = args.json
    targets = list_targets()

    if not targets:
        if use_json:
            print(json.dumps({"targets": []}))
        else:
            print("No targets configured.")
        return EXIT_OK

    all_status = {}
    for name in targets:
        tc = TargetConfig(name)
        cs = _container_status(tc)
        ks = kernel_status(tc)
        ims = image_status(tc)
        all_status[name] = {
            "container": cs,
            "kernel": ks,
            "image": ims,
        }

    if use_json:
        print(json.dumps(all_status, indent=2))
    else:
        # Table output
        hdr = (f"{'Target':<12} {'Container':<14} "
               f"{'Kernel':<26} {'Image':<14}")
        print(hdr)
        print("-" * len(hdr))
        for name, st in all_status.items():
            c = _artifact_label(st["container"])
            k = _artifact_label(st["kernel"])
            i = _artifact_label(st["image"])
            print(f"{name:<12} {c:<14} {k:<26} {i:<14}")

    return EXIT_OK


def _artifact_label(status_dict):
    """Produce a human label like 'current', 'stale (config changed)',
    or 'not built'."""
    if not status_dict.get("built", False):
        return "not built"
    if status_dict.get("stale", False):
        return "stale"
    return "current"


# ------------------------------------------------------------------
# Subcommand: update
# ------------------------------------------------------------------

def cmd_update(args):
    use_json = args.json

    if args.all:
        targets = list_targets()
    else:
        targets = [args.target]

    if not targets:
        return _error("No targets to update", use_json)

    results = {}
    for name in targets:
        tc, err = _load_target(name, use_json)
        if err is not None:
            return err

        updated = []

        if tc.is_stale("container"):
            if not use_json:
                print(f"Rebuilding container for {name}...")
            try:
                _do_build_container(tc)
                updated.append("container")
            except Exception as e:
                return _error(
                    f"Container rebuild failed for {name}: {e}",
                    use_json)

        if tc.is_stale("image"):
            if not use_json:
                print(f"Rebuilding image for {name}...")
            try:
                build_image(tc, force=True)
                updated.append("image")
            except Exception as e:
                return _error(
                    f"Image rebuild failed for {name}: {e}",
                    use_json)

        # Kernel requires --lustre-tree, skip if not stale
        if tc.is_stale("kernel"):
            if args.lustre_tree:
                if not use_json:
                    print(f"Rebuilding kernel for {name}...")
                try:
                    build_kernel(
                        tc, Path(args.lustre_tree).resolve(),
                        force=True)
                    updated.append("kernel")
                except Exception as e:
                    return _error(
                        f"Kernel rebuild failed for {name}: {e}",
                        use_json)
            else:
                if not use_json:
                    print(f"Kernel for {name} is stale but "
                          "--lustre-tree not provided, skipping")

        if not updated:
            results[name] = "up to date"
        else:
            results[name] = updated

    _output(results, use_json)
    return EXIT_OK


# ------------------------------------------------------------------
# Runtime: VM management
# ------------------------------------------------------------------

def _runtime_result(res, use_json):
    """Print a runtime result dict and return the exit code."""
    if use_json:
        print(json.dumps(res, indent=2))
    else:
        if res["output"]:
            print(res["output"])
        if not res["ok"] and not res["output"]:
            print("Command failed with no output",
                  file=sys.stderr)
    return 0 if res["ok"] else res.get("returncode", EXIT_ERROR)


def cmd_vm(args):
    use_json = args.json
    action = args.action
    vm_args = args.vm_args

    if action == "list":
        res = runtime.vm_list(json_output=use_json)
        return _runtime_result(res, use_json)

    if action == "status":
        if not vm_args:
            return _error("vm status requires a VM name",
                          use_json)
        res = runtime.vm_status(vm_args[0],
                                json_output=use_json)
        return _runtime_result(res, use_json)

    if action in ("create", "ensure"):
        if not vm_args:
            return _error(f"vm {action} requires a VM name",
                          use_json)
        name = vm_args[0]
        # Parse optional flags from vm_args[1:]
        kwargs = _parse_vm_kwargs(vm_args[1:])
        fn = (runtime.vm_create if action == "create"
              else runtime.vm_ensure)
        res = fn(name, **kwargs)
        return _runtime_result(res, use_json)

    if action == "destroy":
        if not vm_args:
            return _error("vm destroy requires a VM name",
                          use_json)
        res = runtime.vm_destroy(vm_args[0])
        return _runtime_result(res, use_json)

    if action in ("start", "stop", "restart"):
        if not vm_args:
            return _error(f"vm {action} requires a VM name",
                          use_json)
        fn = getattr(runtime, f"vm_{action}")
        res = fn(vm_args[0])
        return _runtime_result(res, use_json)

    return _error(f"Unknown vm action: {action}", use_json)


def _parse_vm_kwargs(extra_args):
    """Parse --vcpus, --mem, --mdt-disks, --ost-disks, --target
    from a flat list of strings."""
    kwargs = {}
    i = 0
    while i < len(extra_args):
        arg = extra_args[i]
        if arg == "--vcpus" and i + 1 < len(extra_args):
            kwargs["vcpus"] = int(extra_args[i + 1])
            i += 2
        elif arg == "--mem" and i + 1 < len(extra_args):
            kwargs["mem"] = int(extra_args[i + 1])
            i += 2
        elif arg == "--mdt-disks" and i + 1 < len(extra_args):
            kwargs["mdt_disks"] = int(extra_args[i + 1])
            i += 2
        elif arg == "--ost-disks" and i + 1 < len(extra_args):
            kwargs["ost_disks"] = int(extra_args[i + 1])
            i += 2
        elif arg == "--target" and i + 1 < len(extra_args):
            kwargs["target"] = extra_args[i + 1]
            i += 2
        else:
            i += 1
    return kwargs


def cmd_deploy(args):
    use_json = args.json
    build_path = Path(args.build).resolve()
    if not build_path.is_dir():
        return _error(
            f"Build path not found: {build_path}",
            use_json)
    res = runtime.deploy(args.vm, str(build_path),
                         mount=args.mount)
    return _runtime_result(res, use_json)


def cmd_exec(args):
    use_json = args.json
    if not args.cmd:
        return _error("exec requires a command", use_json)
    cmd_str = " ".join(args.cmd)
    timeout = getattr(args, "timeout", 120)
    res = runtime.vm_exec(args.vm, cmd_str, timeout=timeout)
    return _runtime_result(res, use_json)


def cmd_cluster(args):
    use_json = args.json
    action = args.action
    cargs = args.cluster_args

    if action == "create":
        if len(cargs) < 2:
            return _error(
                "cluster create requires a name and "
                "at least one node spec",
                use_json,
                hint="ltvm cluster create <name> "
                     "<role:vm[:disks]> ...")
        name = cargs[0]
        specs = cargs[1:]
        res = runtime.cluster_create(name, *specs)
        return _runtime_result(res, use_json)

    if action == "destroy":
        if not cargs:
            return _error(
                "cluster destroy requires a name",
                use_json)
        res = runtime.cluster_destroy(cargs[0])
        return _runtime_result(res, use_json)

    if action == "deploy":
        if not cargs:
            return _error(
                "cluster deploy requires a name",
                use_json)
        name = cargs[0]
        # Parse --build and --mount from remaining args
        build_path = "."
        mount = False
        i = 1
        while i < len(cargs):
            if cargs[i] == "--build" and i + 1 < len(cargs):
                build_path = cargs[i + 1]
                i += 2
            elif cargs[i] == "--mount":
                mount = True
                i += 1
            else:
                i += 1
        res = runtime.cluster_deploy(name, build_path,
                                     mount=mount)
        return _runtime_result(res, use_json)

    if action == "status":
        if not cargs:
            return _error(
                "cluster status requires a name",
                use_json)
        res = runtime.cluster_status(cargs[0])
        return _runtime_result(res, use_json)

    if action == "exec":
        if len(cargs) < 3:
            return _error(
                "cluster exec requires a name, role, "
                "and command",
                use_json,
                hint="ltvm cluster exec <name> <role> "
                     "'<cmd>'")
        name = cargs[0]
        role = cargs[1]
        cmd_str = " ".join(cargs[2:])
        res = runtime.cluster_exec(name, role, cmd_str)
        return _runtime_result(res, use_json)

    return _error(f"Unknown cluster action: {action}",
                  use_json)


# ------------------------------------------------------------------
# Subcommand: validate
# ------------------------------------------------------------------

def cmd_validate(args):
    """Run validation checks on a built target."""
    use_json = args.json
    tc, err = _load_target(args.target, use_json)
    if err is not None:
        return err

    lustre_tree = None
    if args.lustre_tree:
        lustre_tree = Path(args.lustre_tree).resolve()
        if not lustre_tree.is_dir():
            return _error(
                f"Lustre tree not found: {lustre_tree}",
                use_json)

    try:
        summary = validate_target(
            tc, lustre_tree=lustre_tree,
            verbose=args.verbose)
    except Exception as e:
        return _error(f"Validation failed: {e}", use_json)

    if use_json:
        print(json.dumps(summary, indent=2))
    else:
        print_results(summary, verbose=args.verbose)

    return EXIT_OK if summary["all_passed"] else EXIT_ERROR


# ------------------------------------------------------------------
# Argument parsing
# ------------------------------------------------------------------

def build_parser():
    # Common flags accepted by all subcommands
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument(
        "--json", action="store_true", default=False,
        help="Machine-readable JSON output")
    common.add_argument(
        "-v", "--verbose", action="store_true",
        help="Enable verbose logging")

    p = argparse.ArgumentParser(
        prog="ltvm",
        description="Lustre test VM infrastructure CLI",
        parents=[common])

    sub = p.add_subparsers(dest="command")

    # -- init --
    sp = sub.add_parser(
        "init", parents=[common],
        help="Build container + kernel + image for a target")
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree",
        help="Path to Lustre source tree (required)")
    sp.add_argument(
        "--force", action="store_true",
        help="Rebuild even if artifacts are current")
    sp.set_defaults(func=cmd_init)

    # -- build-container --
    sp = sub.add_parser(
        "build-container", parents=[common],
        help="Build the build container for a target")
    sp.add_argument("target")
    sp.set_defaults(func=cmd_build_container)

    # -- build-kernel --
    sp = sub.add_parser(
        "build-kernel", parents=[common],
        help="Build the kernel for a target")
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree",
        help="Path to Lustre source tree (required)")
    sp.add_argument(
        "--force", action="store_true",
        help="Rebuild even if inputs unchanged")
    sp.set_defaults(func=cmd_build_kernel)

    # -- build-image --
    sp = sub.add_parser(
        "build-image", parents=[common],
        help="Build the VM base image for a target")
    sp.add_argument("target")
    sp.add_argument(
        "--force", action="store_true",
        help="Rebuild even if inputs unchanged")
    sp.set_defaults(func=cmd_build_image)

    # -- shell --
    sp = sub.add_parser(
        "shell", parents=[common],
        help="Enter build container with source mounted")
    sp.add_argument("target")
    sp.add_argument(
        "path", nargs="?", default=".",
        help="Path to mount in container (default: cwd)")
    sp.set_defaults(func=cmd_shell)

    # -- status --
    sp = sub.add_parser(
        "status", parents=[common],
        help="Show build status of all targets")
    sp.set_defaults(func=cmd_status)

    # -- update --
    sp = sub.add_parser(
        "update", parents=[common],
        help="Rebuild stale artifacts for a target")
    sp.add_argument(
        "target", nargs="?", default=None,
        help="Target to update (required unless --all)")
    sp.add_argument(
        "--all", action="store_true",
        help="Update all targets")
    sp.add_argument(
        "--lustre-tree",
        help="Lustre source tree (needed for kernel rebuilds)")
    sp.set_defaults(func=cmd_update)

    # -- validate --
    sp = sub.add_parser(
        "validate", parents=[common],
        help="Validate a built target (boot, packages, "
             "optional Lustre deploy)")
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree",
        help="Path to Lustre build tree "
             "(enables deploy+mount checks)")
    sp.set_defaults(func=cmd_validate)

    # -- vm --
    sp = sub.add_parser(
        "vm", parents=[common],
        help="VM management (create/ensure/destroy/...)")
    sp.add_argument(
        "action",
        choices=["create", "ensure", "destroy",
                 "start", "stop", "restart",
                 "list", "status"],
        help="VM action")
    sp.add_argument("vm_args", nargs="*")
    sp.set_defaults(func=cmd_vm)

    # -- deploy --
    sp = sub.add_parser(
        "deploy", parents=[common],
        help="Deploy Lustre to a VM")
    sp.add_argument("vm", help="VM name")
    sp.add_argument(
        "--build", default=".",
        help="Lustre build tree (default: cwd)")
    sp.add_argument(
        "--mount", action="store_true",
        help="Mount filesystem after deploy")
    sp.set_defaults(func=cmd_deploy)

    # -- exec --
    sp = sub.add_parser(
        "exec", parents=[common],
        help="Execute a command in a VM")
    sp.add_argument("vm", help="VM name")
    sp.add_argument(
        "--timeout", type=int, default=120,
        help="Command timeout in seconds (default: 120)")
    sp.add_argument("cmd", nargs=argparse.REMAINDER,
                    help="Command to run")
    sp.set_defaults(func=cmd_exec)

    # -- cluster --
    sp = sub.add_parser(
        "cluster", parents=[common],
        help="Cluster management (create/destroy/...)")
    sp.add_argument(
        "action",
        choices=["create", "destroy", "deploy",
                 "status", "exec"],
        help="Cluster action")
    sp.add_argument("cluster_args", nargs="*")
    sp.set_defaults(func=cmd_cluster)

    return p


# ------------------------------------------------------------------
# Main
# ------------------------------------------------------------------

def main():
    parser = build_parser()
    args = parser.parse_args()

    level = logging.DEBUG if args.verbose else logging.INFO
    logging.basicConfig(
        level=level,
        format="%(name)s: %(message)s")

    if not args.command:
        parser.print_help()
        return EXIT_ERROR

    # Validate update requires target or --all
    if args.command == "update":
        if not args.target and not args.all:
            return _error(
                "update requires a target or --all",
                args.json,
                hint="ltvm update <target> or ltvm update --all")

    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
