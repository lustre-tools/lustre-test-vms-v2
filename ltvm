    sp.add_argument(
        "action",
        choices=[
            "create",
            "destroy",
            "deploy",
            "status",
            "exec",
            "list",
            "ssh",
        ],
        help="Cluster action",
    )
    sp.add_argument("cluster_args", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_cluster)

    return p


# ------------------------------------------------------------------
# Main
# ------------------------------------------------------------------


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    level = logging.DEBUG if args.verbose else logging.INFO
    logging.basicConfig(level=level, format="%(name)s: %(message)s")

    if not args.command:
        parser.print_help()
        return EXIT_ERROR

    result: int = args.func(args)
    return result


if __name__ == "__main__":
    sys.exit(main())
