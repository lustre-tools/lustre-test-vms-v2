        "--json",
        action="store_true",
        default=False,
        help="Machine-readable JSON output",
    )
    common.add_argument(
        "-v", "--verbose", action="store_true", help="Enable verbose logging"
    )
    common.add_argument(
        "--arch",
        default=None,
        help="Target CPU architecture override (e.g. aarch64). "
        "Defaults to the target's configured arch (usually x86_64).",
    )

    # Shared --kernel flag for subcommands that operate on
    # a specific kernel version within a target
    kernel_arg = argparse.ArgumentParser(add_help=False)
    kernel_arg.add_argument(
        "--kernel",
        default=None,
        help="Kernel version (default: from targets.yaml)",
    )

    # Shared --force flag for build subcommands
    force_arg = argparse.ArgumentParser(add_help=False)
    force_arg.add_argument(
        "--force",
        action="store_true",
        help="Rebuild even if inputs unchanged",
    )

    # Shared --variant flag for build subcommands that operate on a
    # target's variant artifacts (e.g. MOFED).  Default 'base' is the
    # pre-variant behavior.
    variant_arg = argparse.ArgumentParser(add_help=False)
    variant_arg.add_argument(
        "--variant",
        default="base",
        metavar="NAME",
        help="Target variant to build (default: base). "
        "E.g. 'mofed' to layer MOFED on top of the base.",
    )
    variant_arg.add_argument(
        "--mofed-version",
        default=None,
        metavar="VER",
        help="Override mofed_version param for the mofed variant. "
        "Folds into the variant's input hash.",
    )

    # Shared --force-compat flag for subcommands that gate on Lustre-tree
    # compatibility (build + deploy paths).  'refuse' status is bypassed
    # when set; hard errors (parse/IO) are never bypassed.
    force_compat_arg = argparse.ArgumentParser(add_help=False)
    force_compat_arg.add_argument(
        "--force-compat",
        action="store_true",
        help=(
            "Override a Lustre-tree compatibility refusal (not errors).  "
            "Only affects paths that actually invoke the compat gate: "
            "build commands always, and deploy-lustre only when it "
            "rebuilds from source (not bundled snapshots or "
            "--userspace-only, which rely on prior-vetted artifacts)."
        ),
    )

    p = argparse.ArgumentParser(
        prog="ltvm",
        description="Lustre test VM infrastructure CLI",
        parents=[common],
        formatter_class=_HideSuppressedSubcommands,
    )
    p.add_argument(
        "--version",
        action="version",
        version=f"%(prog)s {LTVM_VERSION}",
    )

    sub = p.add_subparsers(dest="command")

    # -- install (host setup) --
    sp = sub.add_parser(
        "install",
        parents=[common],
        help="Install ltvm: QEMU, network, scripts, SSH, ltvm to PATH",
    )
    sp.add_argument(
        "--qemu", action="store_true", help="Build and install QEMU only"
    )
    sp.add_argument(
        "--network", action="store_true", help="Configure bridge + dnsmasq only"
    )
    sp.add_argument(
        "--install",
        action="store_true",
        help="Install scripts and VM directories only",
    )
    sp.add_argument(
        "--ssh", action="store_true", help="Configure host SSH only"
    )
    sp.add_argument(
        "--verify",
        action="store_true",
        help="Check existing setup (no changes)",
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Force rebuild of installed components",
    )
    sp.add_argument(
        "--subnet",
        default="192.168.100",
        help="Bridge subnet (default: 192.168.100)",
    )
    sp.set_defaults(func=cmd_setup)

    # -- update --
    sp = sub.add_parser(
        "update",
        parents=[common],
        help="Pull the latest ltvm from GitHub (git fast-forward)",
    )
