class _HideSuppressedSubcommands(argparse.HelpFormatter):
    """Hide subcommands registered with help=argparse.SUPPRESS."""

    def _format_action(self, action: argparse.Action) -> str:
        if action.help == argparse.SUPPRESS:
            return ""
        return super()._format_action(action)

    def _metavar_formatter(
        self, action: argparse.Action, default_metavar: str
    ) -> Any:
        # For subparser actions, strip suppressed choices from the metavar.
        if hasattr(action, "_name_parser_map"):
            # Aliases point to the same parser instance as the canonical
            # name, so dedupe by id() to keep only the first (canonical)
            # entry per parser.
            seen: set[int] = set()
            visible: list[str] = []
            for name, sp in action._name_parser_map.items():
                if sp.description == argparse.SUPPRESS:
                    continue
                if getattr(sp, "_defaults", {}).get("func") is None:
                    continue
                if id(sp) in seen:
                    continue
                seen.add(id(sp))
                visible.append(name)

            def fmt(tuple_size: int) -> tuple[Any, ...]:
                if tuple_size != 1:
                    return (tuple(visible),)
                return ("{" + ",".join(visible) + "}",)

            return fmt
        return super()._metavar_formatter(action, default_metavar)


def build_parser() -> argparse.ArgumentParser:
    # Common flags accepted by all subcommands
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument(
        "--json",
        action="store_true",
        default=False,
        help="Machine-readable JSON output",
    )
    common.add_argument(
        "-v", "--verbose", action="store_true", help="Enable verbose logging"
    )
    common.add_argument(
        "--arch",
        default=None,
        help="Target CPU architecture override (e.g. aarch64). "
        "Defaults to the target's configured arch (usually x86_64).",
    )

    # Shared --kernel flag for subcommands that operate on
    # a specific kernel version within a target
    kernel_arg = argparse.ArgumentParser(add_help=False)
    kernel_arg.add_argument(
        "--kernel",
        default=None,
        help="Kernel version (default: from kernel.conf)",
    )

    p = argparse.ArgumentParser(
        prog="ltvm",
        description="Lustre test VM infrastructure CLI",
        parents=[common],
        formatter_class=_HideSuppressedSubcommands,
    )
    p.add_argument(
        "--version",
        action="version",
        version=f"%(prog)s {LTVM_VERSION}",
    )

    sub = p.add_subparsers(dest="command")

    # -- install (host setup) --
    sp = sub.add_parser(
        "install",
        parents=[common],
        aliases=["setup"],
        help="Install ltvm: QEMU, network, scripts, SSH, ltvm to PATH",
    )
    sp.add_argument(
        "--qemu", action="store_true", help="Build and install QEMU only"
    )
    sp.add_argument(
        "--network", action="store_true", help="Configure bridge + dnsmasq only"
    )
    sp.add_argument(
        "--install",
        action="store_true",
        help="Install scripts and VM directories only",
    )
    sp.add_argument(
        "--ssh", action="store_true", help="Configure host SSH only"
    )
    sp.add_argument(
        "--verify",
        action="store_true",
        help="Check existing setup (no changes)",
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Force rebuild of installed components",
    )
    sp.add_argument(
        "--subnet",
        default="192.168.100",
        help="Bridge subnet (default: 192.168.100)",
    )
    sp.set_defaults(func=cmd_setup)

    # -- update --
    sp = sub.add_parser(
        "update",
        parents=[common],
        help="Pull the latest ltvm from GitHub (git fast-forward)",
    )
    sp.add_argument(
        "--check",
        action="store_true",
        help="Check whether an update is available without pulling",
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Update even if the working tree has local changes",
    )
    sp.set_defaults(func=cmd_update)

    # -- build-all --
    sp = sub.add_parser(
        "build-all",
        parents=[common, kernel_arg],
        help="Build container + kernel + image from scratch",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree", help="Path to Lustre source tree (default: cwd)"
    )
    sp.add_argument(
        "--lustre-build",
        action="store_true",
        help="Also build Lustre against the target kernel",
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Rebuild even if artifacts are current",
    )
    sp.add_argument(
        "--force-compat",
        action="store_true",
        help="Override a Lustre-tree compatibility refusal (not errors)",
    )
    sp.set_defaults(func=cmd_build_all)

    # -- build-container --
    sp = sub.add_parser(
        "build-container",
        parents=[common],
        help="Build the build container for a target",
    )
    sp.add_argument("target")
    sp.set_defaults(func=cmd_build_container)

    # -- build-kernel --
    sp = sub.add_parser(
        "build-kernel",
        parents=[common, kernel_arg],
        help="Build the kernel for a target",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree", help="Path to Lustre source tree (default: cwd)"
    )
    sp.add_argument(
        "--force", action="store_true", help="Rebuild even if inputs unchanged"
    )
    sp.add_argument(
        "--force-compat",
        action="store_true",
        help="Override a Lustre-tree compatibility refusal (not errors)",
    )
    sp.set_defaults(func=cmd_build_kernel)

    # -- build-image --
    sp = sub.add_parser(
        "build-image",
        parents=[common, kernel_arg],
        help="Build the VM base image for a target",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--force", action="store_true", help="Rebuild even if inputs unchanged"
    )
    sp.add_argument(
        "--no-lustre",
        action="store_true",
        help="Do not bake Lustre modules+userland into the image, "
        "even if staging is present",
    )
    sp.add_argument(
        "--lustre-tree",
        default=None,
        metavar="PATH",
        help="Path to Lustre source tree (default: cwd) -- used to "
        "find per-kernel Lustre staging to bake into the image",
    )
    sp.set_defaults(func=cmd_build_image)

    # -- build-lustre --
    sp = sub.add_parser(
        "build-lustre",
        parents=[common, kernel_arg],
        help="Build a Lustre source tree against the target kernel build-tree",
    )
    sp.add_argument(
        "target", nargs="?", default="rocky9", help="Target (default: rocky9)"
    )
    sp.add_argument(
        "lustre_tree_pos",
        nargs="?",
        default=None,
        metavar="lustre-tree",
        help="Path to Lustre source tree (positional or --lustre-tree)",
    )
    sp.add_argument(
        "--lustre-tree", help="Path to Lustre source tree (default: cwd)"
    )
    sp.add_argument(
        "--enable-server",
        action="store_true",
        default=False,
        help="Force --enable-server (default: per target.conf)",
    )
    sp.add_argument(
        "--disable-server",
        action="store_true",
        default=False,
        help="Force --disable-server",
    )
    sp.add_argument(
        "--configure", help="Extra configure arguments (quoted string)"
    )
    sp.add_argument(
        "--jobs", type=int, default=None, help="Parallel jobs (default: nproc)"
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Clean and reconfigure before building",
    )
    sp.add_argument(
        "--force-compat",
        action="store_true",
        help="Override a Lustre-tree compatibility refusal (not errors)",
    )
    sp.set_defaults(func=cmd_build_lustre)

    # -- package (hidden: maintainer use only) --
    sp = sub.add_parser(
        "package",
        parents=[common, kernel_arg],
        help=argparse.SUPPRESS,
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree",
        help=(
            "Path to the Lustre source tree to bundle (default: cwd, "
            "or wherever ltvm finds a tree).  Lustre is bundled by "
            "default; pass --no-lustre to opt out."
        ),
    )
    sp.add_argument(
        "--no-lustre",
        action="store_true",
        default=False,
        help=(
            "Publish a kernel-only package without bundled Lustre.  "
            "Consumers will need to build Lustre themselves on first "
            "deploy.  Only use this for interim kernel-test releases."
        ),
    )
    sp.add_argument(
        "--output",
        default=None,
        help="Output directory for tarball (default: output/)",
    )
    sp.add_argument(
        "--force-compat",
        action="store_true",
        help="Override a Lustre-tree compatibility refusal (not errors)",
    )
    sp.set_defaults(func=cmd_package)

    # -- fetch --
    sp = sub.add_parser(
        "fetch",
        parents=[common],
        help="Download pre-built target artifacts from GitHub",
    )
    sp.add_argument(
        "target", nargs="?", default=None, help="Target name (e.g. rocky9)"
    )
    sp.add_argument(
        "filter",
        nargs="?",
        default=None,
        help="Optional filter (e.g. '5.14', '611')",
    )
    sp.add_argument(
        "--list", action="store_true", help="List available releases"
    )
    sp.add_argument(
        "--url", default=None, help="Direct URL (skip GitHub lookup)"
    )
    sp.set_defaults(func=cmd_fetch)

    # -- publish (hidden: maintainer use only) --
    sp = sub.add_parser(
        "publish",
        parents=[common, kernel_arg],
        help=argparse.SUPPRESS,
    )
    sp.add_argument("target")
    sp.add_argument(
        "--tag",
        default=None,
        help="Release tag (default: derived from tarball name)",
    )
    sp.add_argument(
        "--tarball",
        default=None,
        help="Path to tarball (default: auto-detect from output/)",
    )
    sp.set_defaults(func=cmd_publish)

    # -- build-shell --
    sp = sub.add_parser(
        "build-shell",
        parents=[common],
        help="Enter build container with source mounted",
    )
    sp.add_argument("target")
    sp.add_argument(
        "path",
        nargs="?",
        default=".",
        help="Path to mount in container (default: cwd)",
    )
    sp.set_defaults(func=cmd_build_shell)

    # -- build-status --
    sp = sub.add_parser(
        "build-status",
        parents=[common],
        help="Show build status of all targets",
    )
    sp.set_defaults(func=cmd_status)

    # -- validate --
    sp = sub.add_parser(
        "validate",
        parents=[common],
        help="Check Lustre-tree compatibility for a target (read-only)",
    )
    sp.add_argument("target")
    sp.add_argument(
        "--lustre-tree",
        help="Path to Lustre source tree (default: ~/lustre-release)",
    )
    sp.add_argument(
        "--force",
        action="store_true",
        help="Downgrade 'refuse' exit code to 0 (message still printed)",
    )
    sp.set_defaults(func=cmd_validate)

    # -- VM lifecycle: create --
    _vm_create_args = argparse.ArgumentParser(add_help=False)
    _vm_create_args.add_argument(
        "--vcpus", type=int, default=2, help="vCPU count (default: 2)"
    )
    _vm_create_args.add_argument(
        "--mem",
        type=int,
        default=None,
        help="Memory in MB (default: target's "
        "default_mem from targets.yaml, "
        "else 2048)",
    )
    _vm_create_args.add_argument("--ip", default=None, help="Static IP address")
    _vm_create_args.add_argument(
        "--rootfs", default=None, help="Explicit rootfs image path"
    )
    _vm_create_args.add_argument(
        "--image", default=None, help="Explicit base image path"
    )
    _vm_create_args.add_argument(
        "--kernel", default=None, help="Explicit kernel path"
    )
    _vm_create_args.add_argument(
        "--os", default=None, help="OS target (e.g. rocky9)"
    )
    _vm_create_args.add_argument(
        "--mdt-disks",
        dest="mdt_disks",
        type=int,
        default=1,
        help="Number of MDT disks (default: 1)",
    )
    _vm_create_args.add_argument(
        "--ost-disks",
        dest="ost_disks",
        type=int,
        default=2,
        help="Number of OST disks (default: 2)",
    )
    _vm_create_args.add_argument(
        "--disk-size",
        dest="disk_size",
        default=None,
        help=(
            "Per-disk size with suffix M or G (e.g. 500M, 2G); "
            "default 500M, max 100G"
        ),
    )

    sp = sub.add_parser(
        "create",
        parents=[common, _vm_create_args],
        help="Create a new VM",
    )
    sp.add_argument("name", help="VM name (e.g. co1-single)")
    sp.set_defaults(func=cmd_create)

    # -- VM lifecycle: ensure --
    sp = sub.add_parser(
        "ensure",
        parents=[common, _vm_create_args],
        help="Create VM if it does not exist, or start it if stopped",
    )
    sp.add_argument("name", help="VM name (e.g. co1-single)")
    sp.set_defaults(func=cmd_ensure)

    # -- VM lifecycle: destroy --
    sp = sub.add_parser(
        "destroy",
        parents=[common],
        help="Destroy one or more VMs",
    )
    sp.add_argument("names", nargs="+", help="VM name(s)")
    sp.set_defaults(func=cmd_destroy)

    # -- VM lifecycle: start --
    sp = sub.add_parser(
        "start",
        parents=[common],
        help="Start one or more stopped VMs",
    )
    sp.add_argument("names", nargs="+", help="VM name(s)")
    sp.set_defaults(func=cmd_vm_start)

    # -- VM lifecycle: stop --
    sp = sub.add_parser(
        "stop",
        parents=[common],
        help="Stop one or more running VMs",
    )
    sp.add_argument("names", nargs="+", help="VM name(s)")
    sp.set_defaults(func=cmd_vm_stop)

    # -- VM info: list --
    sp = sub.add_parser(
        "list",
        parents=[common],
        help="List all VMs",
    )
    sp.set_defaults(func=cmd_list)

    # -- VM access: ssh --
    sp = sub.add_parser(
        "ssh",
        parents=[common],
        help="SSH into a VM (replaces shell with ssh session)",
    )
    sp.add_argument("name", help="VM name")
    sp.add_argument(
        "command", nargs=argparse.REMAINDER, help="Optional command to run"
    )
    sp.set_defaults(func=cmd_vm_ssh)

    # -- VM observability: console-log --
    sp = sub.add_parser(
        "console-log",
        parents=[common],
        help="Show QEMU console log for a VM",
    )
    sp.add_argument("name", help="VM name")
    sp.add_argument(
        "--lines",
        type=int,
        default=50,
        help="Number of lines to show (default: 50)",
    )
    sp.set_defaults(func=cmd_console_log)

    # -- VM observability: dmesg --
    sp = sub.add_parser(
        "dmesg",
        parents=[common],
        help="Show kernel dmesg from a VM",
    )
    sp.add_argument("name", help="VM name")
    sp.add_argument(
        "--tail",
        type=int,
        default=100,
        help="Number of lines to show (default: 100)",
    )
    sp.set_defaults(func=cmd_dmesg)

    # -- VM crash: crash-collect --
    sp = sub.add_parser(
        "crash-collect",
        parents=[common],
        help="Collect vmcore from a VM (optionally trigger crash first)",
    )
    sp.add_argument("name", help="VM name")
    sp.add_argument(
        "--outdir",
        default="/tmp/crashes",
        help="Local directory for crash dumps (default: /tmp/crashes)",
    )
    sp.add_argument(
        "--trigger",
        action="store_true",
        default=False,
        help="Trigger a crash via sysrq before collecting",
    )
    sp.add_argument(
        "--wait",
        type=int,
        default=120,
        help="Seconds to wait for VM to come back (default: 120)",
    )
    sp.add_argument(
        "--mod-dir",
        dest="mod_dir",
        default=None,
        help="Lustre build tree for triage (enables auto-triage)",
    )
    sp.set_defaults(func=cmd_crash_collect)

    # -- VM crash: nmi --
    sp = sub.add_parser(
        "nmi",
        parents=[common],
        help="Inject NMI into a VM (triggers kernel panic + kdump)",
    )
    sp.add_argument("name", help="VM name")
    sp.set_defaults(func=cmd_nmi)

    # -- VM snapshot: snapshot --
    sp = sub.add_parser(
        "snapshot",
        parents=[common],
        help="Create a snapshot of a VM's overlay disk",
    )
    sp.add_argument("name", help="VM name")
    sp.add_argument(
        "tag",
        nargs="?",
        default=None,
        help="Snapshot tag (default: auto-generated timestamp)",
    )
    sp.set_defaults(func=cmd_snapshot)

    # -- VM snapshot: restore --
    sp = sub.add_parser(
        "restore",
        parents=[common],
        help="Restore a VM to a snapshot (or list snapshots if no tag)",
    )
    sp.add_argument("name", help="VM name")
    sp.add_argument(
        "tag",
        nargs="?",
        default=None,
        help="Snapshot tag to restore (omit to list snapshots)",
    )
    sp.set_defaults(func=cmd_restore)

    # -- VM maintenance: doctor --
    sp = sub.add_parser(
        "doctor",
        parents=[common],
        help="Check for and optionally fix VM infrastructure issues",
    )
    sp.add_argument(
        "--fix",
        action="store_true",
        default=False,
        help="Fix issues automatically",
    )
    sp.set_defaults(func=cmd_doctor)

    # -- deploy-lustre --
    sp = sub.add_parser(
        "deploy-lustre",
        parents=[common, kernel_arg],
