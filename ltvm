    _add_target_arg(bmkp, required=True)
    bmkp.set_defaults(func=cmd_build_mofed_kmods)

    bstp = build_sub.add_parser(
        "status",
        parents=[common],
        help="Show build status of all targets",
    )
    bstp.set_defaults(func=cmd_status)

    def _build_no_action(args: argparse.Namespace) -> int:
        build_parser.print_help()
        return EXIT_ERROR

    build_parser.set_defaults(func=_build_no_action)

    # -- target (list | show | clean | validate | fetch | package | publish) --
    target_parser = sub.add_parser(
        "target",
        parents=[common],
        help="Target OS management "
        "(list/show/clean/validate/fetch/package/publish)",
    )
    target_sub = target_parser.add_subparsers(
        dest="target_action", metavar="<action>"
    )

    tlp = target_sub.add_parser(
        "list",
        parents=[common],
        help="List configured target OSes",
    )
    tlp.set_defaults(func=cmd_targets)

    tshp = target_sub.add_parser(
        "show",
        parents=[common],
        help="Show details for one target",
    )
    _add_target_arg(tshp, required=True)
    tshp.set_defaults(func=cmd_target_show)

    tcp = target_sub.add_parser(
        "clean",
        parents=[common],
        help="Remove built artifacts for a target",
