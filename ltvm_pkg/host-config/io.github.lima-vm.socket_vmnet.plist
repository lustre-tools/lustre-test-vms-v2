<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>Label</key>
		<string>io.github.lima-vm.socket_vmnet</string>
		<key>Program</key>
		<string>@SOCKET_VMNET_BIN@</string>
		<key>ProgramArguments</key>
		<array>
			<string>@SOCKET_VMNET_BIN@</string>
			<string>--vmnet-gateway=@VMNET_GATEWAY@</string>
			<string>@SOCKET_VMNET_SOCKET@</string>
		</array>
		<key>StandardErrorPath</key>
		<string>/var/log/socket_vmnet/stderr</string>
		<key>StandardOutPath</key>
		<string>/var/log/socket_vmnet/stdout</string>
		<key>RunAtLoad</key>
		<true />
		<key>KeepAlive</key>
		<true />
		<key>UserName</key>
		<string>root</string>
		<key>ProcessType</key>
		<string>Interactive</string>
	</dict>
</plist>
